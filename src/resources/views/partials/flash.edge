@if(flashMessages.has('success'))
  <div
    class="alert alert-success"
    style="background-color: #c6f6d5; color: #2f855a; padding: 10px; margin-bottom: 15px; border-radius: 5px;"
  >
    {{ old('success') }}
  </div>
@end

@if(flashMessages.has('error'))
  <div
    class="alert alert-danger"
    style="background-color: #fed7d7; color: #c53030; padding: 10px; margin-bottom: 15px; border-radius: 5px;"
  >
    {{ old('error') }}
  </div>
@end
